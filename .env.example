# WorksideQA local environment examples.
# Copy to .env.local and fill only the values needed for local runs.

WORKSIDEQA_ENVIRONMENT=local
WORKSIDEQA_HEADLESS=true
WORKSIDEQA_OPENAI_MODEL=gpt-5.4-mini
OPENAI_API_KEY=

# Optional read-only Firebase verification.
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_ACCESS_TOKEN=

RADIUSIQ_DEMO_EMAIL=
RADIUSIQ_DEMO_PASSWORD=

MERXUS_DEMO_EMAIL=
MERXUS_DEMO_PASSWORD=

SAGESET_DEMO_EMAIL=
SAGESET_DEMO_PASSWORD=

SUPPORT_CONSOLE_DEMO_EMAIL=
SUPPORT_CONSOLE_DEMO_PASSWORD=

ROUTE_LOGISTICS_DEMO_EMAIL=
ROUTE_LOGISTICS_DEMO_PASSWORD=

ANYRYDE_DEMO_EMAIL=
ANYRYDE_DEMO_PASSWORD=

RADIUSIQ_API_HEALTH_URL=
MERXUS_API_HEALTH_URL=
SAGESET_API_HEALTH_URL=
SUPPORT_CONSOLE_API_HEALTH_URL=
ROUTE_LOGISTICS_API_HEALTH_URL=
ANYRYDE_API_HEALTH_URL=

SAGESET_PUSH_TEST_TOKEN=
ROUTE_LOGISTICS_PUSH_TEST_TOKEN=
ANYRYDE_PUSH_TEST_TOKEN=
