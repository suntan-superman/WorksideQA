{
  "name": "worksideqa",
  "version": "0.1.0-alpha",
  "description": "Shared QA automation platform for Workside Software products.",
  "main": "packages/qa-core/src/index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "qa": "node packages/qa-core/src/cli.js",
    "qa:radiusiq": "node packages/qa-core/src/cli.js --product radiusiq --suite smoke --start-server",
    "qa:merxus": "node packages/qa-core/src/cli.js --product merxus --suite smoke --start-server",
    "qa:sageset": "node packages/qa-core/src/cli.js --product sageset --suite smoke --start-server",
    "qa:all": "node packages/qa-core/src/cli.js --all --suite smoke",
    "qa:radiusiq:dry": "node packages/qa-core/src/cli.js --product radiusiq --suite smoke --dry-run",
    "qa:all:dry": "node packages/qa-core/src/cli.js --all --suite smoke --dry-run",
    "qa:release": "node packages/qa-core/src/release-workflow.js",
    "qa:release:no-open": "node packages/qa-core/src/release-workflow.js --no-open",
    "qa:release:dry": "node packages/qa-core/src/release-workflow.js --dry-run --no-open",
    "qa:release:radiusiq": "node packages/qa-core/src/release-workflow.js --product radiusiq",
    "qa:release:merxus": "node packages/qa-core/src/release-workflow.js --product merxus",
    "qa:dashboard:data": "node packages/qa-reporting/src/build-dashboard-data.js",
    "qa:ai-review": "node packages/qa-core/src/cli.js --ai-review",
    "qa:bug-report": "node packages/qa-openai/src/generate-bug-report.js",
    "qa:env": "node packages/qa-config/src/print-env-status.js",
    "qa:report": "node packages/qa-reporting/src/open-latest-report.js",
    "test": "node packages/qa-core/src/cli.js --product radiusiq --suite smoke --dry-run"
  },
  "keywords": [],
  "author": "Workside Software LLC",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "pngjs": "^7.0.0"
  }
}
