{
  "key": "anyryde",
  "name": "AnyRyde",
  "type": "expo-react-native",
  "status": "active",
  "baseUrl": {
    "local": "http://127.0.0.1:3000",
    "staging": "https://anyryde-staging.netlify.app",
    "production": "https://anyryde.com"
  },
  "devServer": {
    "enabled": true,
    "workingDirectory": "C:/Users/sjroy/Source/rydeIQ/rydeIQWeb",
    "command": "npm run start",
    "port": 3000,
    "healthUrl": "http://127.0.0.1:3000",
    "healthTimeoutMs": 90000
  },
  "auth": {
    "strategy": "email-password",
    "loginPath": "/login",
    "demoUserEnvKey": "ANYRYDE_DEMO_EMAIL",
    "demoPasswordEnvKey": "ANYRYDE_DEMO_PASSWORD"
  },
  "firebase": {
    "enabled": true,
    "projectId": "anyryde-prod"
  },
  "api": {
    "enabled": true,
    "healthChecks": [
      {
        "name": "cloud-run-health",
        "urlEnvKey": "ANYRYDE_API_HEALTH_URL",
        "expectedStatus": 200,
        "required": false
      }
    ]
  },
  "performance": {
    "enabled": true,
    "maxNetworkFailures": 0
  },
  "accessibility": {
    "enabled": true,
    "tags": ["wcag2a", "wcag2aa", "wcag21a", "wcag21aa"]
  },
  "visualRegression": {
    "enabled": true,
    "threshold": 0.01,
    "maxMismatchRatio": 0.0025
  },
  "ai": {
    "enabled": false
  },
  "mobile": {
    "enabled": true,
    "flows": [
      {
        "name": "mobile-smoke",
        "path": "products/anyryde/workflows/mobile-smoke.yaml",
        "runByDefault": false
      }
    ],
    "pushNotifications": {
      "enabled": true,
      "testTokenEnvKey": "ANYRYDE_PUSH_TEST_TOKEN"
    }
  },
  "suites": {
    "smoke": ["load", "login", "trip-list", "basic-navigation"],
    "regression": ["login", "trip-list", "booking-flow", "notifications"],
    "release": ["smoke", "api", "firebase", "accessibility", "performance", "mobile"]
  },
  "personas": ["rider", "driver"],
  "tags": ["web", "mobile", "firebase", "rideshare"]
}
