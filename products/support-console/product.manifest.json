{
  "key": "support-console",
  "name": "Workside Support Console",
  "type": "react-vite",
  "status": "active",
  "baseUrl": {
    "local": "http://127.0.0.1:5176",
    "staging": "https://workside-support-console-staging.netlify.app",
    "production": "https://support.workside.software"
  },
  "devServer": {
    "enabled": true,
    "workingDirectory": "C:/Users/sjroy/Source/WorksideSupportConsole",
    "command": "npx vite --host 127.0.0.1 --port 5176",
    "port": 5176,
    "healthUrl": "http://127.0.0.1:5176",
    "healthTimeoutMs": 60000
  },
  "auth": {
    "strategy": "email-password",
    "loginPath": "/",
    "demoUserEnvKey": "SUPPORT_CONSOLE_DEMO_EMAIL",
    "demoPasswordEnvKey": "SUPPORT_CONSOLE_DEMO_PASSWORD",
    "selectors": {
      "email": "#auth-email-input",
      "password": "#auth-password-input",
      "submit": "#firebase-login-button"
    }
  },
  "firebase": {
    "enabled": true,
    "projectId": "workside-support-prod"
  },
  "api": {
    "enabled": true,
    "healthChecks": [
      {
        "name": "cloud-run-health",
        "urlEnvKey": "SUPPORT_CONSOLE_API_HEALTH_URL",
        "expectedStatus": 200,
        "required": false
      }
    ]
  },
  "performance": {
    "enabled": true,
    "maxNetworkFailures": 0
  },
  "accessibility": {
    "enabled": true,
    "tags": ["wcag2a", "wcag2aa", "wcag21a", "wcag21aa"]
  },
  "visualRegression": {
    "enabled": true,
    "threshold": 0.01,
    "maxMismatchRatio": 0.0025
  },
  "ai": {
    "enabled": false
  },
  "mobile": {
    "enabled": false
  },
  "suites": {
    "smoke": ["load", "login", "ticket-list", "basic-navigation"],
    "regression": ["login", "ticket-list", "ticket-detail", "owner-routing"],
    "release": ["smoke", "api", "firebase", "accessibility", "performance"]
  },
  "personas": ["support-agent"],
  "tags": ["web", "firebase", "support"]
}
